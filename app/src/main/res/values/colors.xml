<?xml version="1.0" encoding="utf-8"?>
<!--
  Material 3 palette - light variant.
  Role-based naming; consumed by themes.xml via ?attr/color* references.
  Dark counterparts live in res/values-night/colors.xml.
  Generated from a neutral blue seed: hue similar to MIUI / MT Manager neutrals.
-->
<resources>
    <color name="md_primary">#2D55B7</color>
    <color name="md_on_primary">#FFFFFF</color>
    <color name="md_primary_container">#DBE1FF</color>
    <color name="md_on_primary_container">#001550</color>

    <color name="md_secondary">#5B5D72</color>
    <color name="md_on_secondary">#FFFFFF</color>
    <color name="md_secondary_container">#E0E1F9</color>
    <color name="md_on_secondary_container">#181A2C</color>

    <color name="md_surface">#FAF8FD</color>
    <color name="md_on_surface">#1B1B1F</color>
    <color name="md_on_surface_variant">#45464F</color>

    <color name="md_surface_container_low">#F4F2F8</color>
    <color name="md_surface_container">#EEEDF3</color>
    <color name="md_surface_container_high">#E8E7ED</color>
    <color name="md_surface_container_highest">#E2E1E8</color>

    <color name="md_outline">#767680</color>
    <color name="md_outline_variant">#C6C6D0</color>

    <color name="md_error">#BA1A1A</color>
    <color name="md_on_error">#FFFFFF</color>

    <!-- Selected-item background for file rows (semi-transparent primary). -->
    <color name="row_selected_bg">#332D55B7</color>

    <!--
      Badge colors per FileCategory. Medium-saturation, ~40-50% lightness so badges read clearly
      on the light surface (#FAF8FD). Text inside each badge is locked to white (see
      @color/badge_on_color) so contrast holds regardless of the bg hue.
    -->
    <color name="badge_folder">#F9A825</color>
    <color name="badge_text">#546E7A</color>
    <color name="badge_code">#2E7D32</color>
    <color name="badge_image">#7B1FA2</color>
    <color name="badge_video">#D81B60</color>
    <color name="badge_audio">#EF6C00</color>
    <color name="badge_archive">#5D4037</color>
    <color name="badge_pdf">#B71C1C</color>
    <color name="badge_doc">#1565C0</color>
    <color name="badge_apk">#689F38</color>
    <color name="badge_unknown">#757575</color>
    <color name="badge_on_color">#FFFFFF</color>
</resources>
