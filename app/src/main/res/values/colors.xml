<?xml version="1.0" encoding="utf-8"?>
<!--
  Material 3 palette - light variant.
  Role-based naming; consumed by themes.xml via ?attr/color* references.
  Dark counterparts live in res/values-night/colors.xml.
  Generated from a neutral blue seed: hue similar to MIUI / MT Manager neutrals.
-->
<resources>
    <color name="md_primary">#2D55B7</color>
    <color name="md_on_primary">#FFFFFF</color>
    <color name="md_primary_container">#DBE1FF</color>
    <color name="md_on_primary_container">#001550</color>

    <color name="md_secondary">#5B5D72</color>
    <color name="md_on_secondary">#FFFFFF</color>
    <color name="md_secondary_container">#E0E1F9</color>
    <color name="md_on_secondary_container">#181A2C</color>

    <!--
      Pane content surface. Pure white in light mode (no tint) so saturated brand colors stay
      brand-accurate. Bottom bar shares this color (one content zone) — chrome lives above.
    -->
    <color name="md_surface">#FFFFFF</color>
    <color name="md_on_surface">#1B1B1F</color>
    <color name="md_on_surface_variant">#5F5F66</color>

    <color name="md_surface_container_low">#F8F8F8</color>
    <color name="md_surface_container">#F2F2F2</color>
    <color name="md_surface_container_high">#ECECEC</color>
    <color name="md_surface_container_highest">#E4E4E4</color>

    <!--
      Chrome (action bar + status bar): darker than the pane so the eye can immediately read
      "where am I". Dark gray in light mode (MT-style) — still distinct from the white pane.
      Dark mode uses pure black (see values-night/colors.xml).
    -->
    <color name="md_chrome_bg">#212121</color>
    <color name="md_chrome_on_bg">#FFFFFF</color>
    <color name="md_chrome_on_bg_variant">#B5B5B5</color>

    <!--
      Subtle active-pane border. Light-blue accent matches the "white + gray + light-blue" light
      palette guidance — not the saturated M3 colorPrimary that read as harsh.
    -->
    <color name="pane_indicator_active">#42A5F5</color>

    <color name="md_outline">#767680</color>
    <color name="md_outline_variant">#C6C6D0</color>

    <color name="md_error">#BA1A1A</color>
    <color name="md_on_error">#FFFFFF</color>

    <!-- Selected-item background for file rows (semi-transparent primary). -->
    <color name="row_selected_bg">#332D55B7</color>

    <!--
      Badge colors per FileCategory. Medium-saturation, ~40-50% lightness so badges read clearly
      on the light surface (#FAF8FD). Text inside each badge is locked to white (see
      @color/badge_on_color) so contrast holds regardless of the bg hue.
    -->
    <!--
      Folder uses dark slate in BOTH modes (MT-faithful). The white folder glyph inside reads on
      any surface because the badge holds its own contrast. Changing per-mode would either kill
      contrast (light bg + white glyph) or look out of place.
    -->
    <color name="badge_folder">#37474F</color>

    <!-- TOP-7 category badges (used for files that get a white glyph instead of ext text). -->
    <color name="badge_image">#7B1FA2</color>
    <color name="badge_video">#D81B60</color>
    <color name="badge_audio">#EF6C00</color>
    <color name="badge_archive">#5D4037</color>
    <color name="badge_pdf">#B71C1C</color>
    <color name="badge_apk">#689F38</color>

    <!-- Legacy category colors kept for non-TOP-7 branches that still pass through FileLabel. -->
    <color name="badge_text">#546E7A</color>
    <color name="badge_code">#2E7D32</color>
    <color name="badge_doc">#1565C0</color>
    <color name="badge_unknown">#757575</color>
    <color name="badge_on_color">#FFFFFF</color>

    <!--
      Brand colors for the file-shape + ext-text approach (per-extension).
      Sourced from each tool's official brand color so .py looks "Python", .docx looks "Word", etc.
      Dark-mode counterparts are softened in values-night/colors.xml so they read on dark surfaces.
    -->
    <color name="brand_python">#3776AB</color>
    <color name="brand_java">#E76F00</color>
    <color name="brand_kotlin">#7F52FF</color>
    <color name="brand_js">#F0DB4F</color>
    <color name="brand_ts">#3178C6</color>
    <color name="brand_go">#00ADD8</color>
    <color name="brand_rust">#CE422B</color>
    <color name="brand_ruby">#CC342D</color>
    <color name="brand_php">#777BB4</color>
    <color name="brand_c_lang">#A8B9CC</color>
    <color name="brand_cpp">#00599C</color>
    <color name="brand_csharp">#9B4F96</color>
    <color name="brand_html">#E34F26</color>
    <color name="brand_css">#1572B6</color>
    <color name="brand_json">#5C5C5C</color>
    <color name="brand_xml">#A87E5D</color>
    <color name="brand_yaml">#CB171E</color>
    <color name="brand_sh">#4EAA25</color>
    <color name="brand_sql">#336791</color>
    <color name="brand_md">#383838</color>
    <color name="brand_word">#185ABD</color>
    <color name="brand_excel">#107C41</color>
    <color name="brand_ppt">#C43E1C</color>
    <color name="brand_default">#6E6E6E</color>
</resources>
