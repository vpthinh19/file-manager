<?xml version="1.0" encoding="utf-8"?>
<!--
  Material 3 palette - dark variant.
  Color names mirror res/values/colors.xml; the DayNight theme picks the right set per uiMode.
-->
<resources>
    <color name="md_primary">#B6C5FF</color>
    <color name="md_on_primary">#002780</color>
    <color name="md_primary_container">#053EB2</color>
    <color name="md_on_primary_container">#DBE1FF</color>

    <color name="md_secondary">#C4C5DD</color>
    <color name="md_on_secondary">#2D2F42</color>
    <color name="md_secondary_container">#444559</color>
    <color name="md_on_secondary_container">#E0E1F9</color>

    <!--
      Dark pane lifted to #303030 (MT-style content zone). Sits ABOVE chrome (#000000) so the
      eye sees a clear hierarchy: pure-black chrome → lifted-gray content. Bottom bar shares
      this surface color so the lifted zone reads as one block.
    -->
    <color name="md_surface">#303030</color>
    <color name="md_on_surface">#ECECEC</color>
    <color name="md_on_surface_variant">#B5B5B5</color>

    <color name="md_surface_container_low">#262626</color>
    <color name="md_surface_container">#303030</color>
    <color name="md_surface_container_high">#3A3A3A</color>
    <color name="md_surface_container_highest">#454545</color>

    <!-- Chrome pure black — maximum contrast against the lifted #303030 pane. -->
    <color name="md_chrome_bg">#000000</color>
    <color name="md_chrome_on_bg">#FFFFFF</color>
    <color name="md_chrome_on_bg_variant">#B0B0B0</color>

    <!-- Active pane border in dark mode — same blue accent, slightly lighter to read on #303030. -->
    <color name="pane_indicator_active">#64B5F6</color>

    <color name="md_outline">#8F909A</color>
    <color name="md_outline_variant">#45464F</color>

    <color name="md_error">#FFB4AB</color>
    <color name="md_on_error">#690005</color>

    <!-- Selected-item background for file rows (semi-transparent primary). -->
    <color name="row_selected_bg">#33B6C5FF</color>

    <!--
      Badge colors per FileCategory (dark mode). Higher lightness (60-75%) so badges read on the
      dark surface (#131318). Text stays white — light bg badges keep contrast because of the
      shape's edge anti-aliasing on dark surface.
    -->
    <!-- Folder: same dark slate family (MT-faithful), slightly brighter for dark surface contrast. -->
    <color name="badge_folder">#455A64</color>

    <!-- TOP-7 category badges (dark mode — pastel for surface contrast). -->
    <color name="badge_image">#CE93D8</color>
    <color name="badge_video">#F48FB1</color>
    <color name="badge_audio">#FFB74D</color>
    <color name="badge_archive">#BCAAA4</color>
    <color name="badge_pdf">#EF9A9A</color>
    <color name="badge_apk">#C5E1A5</color>

    <!-- Legacy category colors (dark). -->
    <color name="badge_text">#90A4AE</color>
    <color name="badge_code">#A5D6A7</color>
    <color name="badge_doc">#64B5F6</color>
    <color name="badge_unknown">#BDBDBD</color>
    <color name="badge_on_color">#0E0E12</color>

    <!-- Brand colors (dark mode — lightened/desaturated versions of brand palette). -->
    <color name="brand_python">#6FA8DC</color>
    <color name="brand_java">#FFB74D</color>
    <color name="brand_kotlin">#B388FF</color>
    <color name="brand_js">#FFF59D</color>
    <color name="brand_ts">#81B5E6</color>
    <color name="brand_go">#80DEEA</color>
    <color name="brand_rust">#FF8A65</color>
    <color name="brand_ruby">#EF9A9A</color>
    <color name="brand_php">#B3B7DD</color>
    <color name="brand_c_lang">#CFD8DC</color>
    <color name="brand_cpp">#82B1FF</color>
    <color name="brand_csharp">#CE93D8</color>
    <color name="brand_html">#FFAB91</color>
    <color name="brand_css">#90CAF9</color>
    <color name="brand_json">#B0B0B0</color>
    <color name="brand_xml">#D7B895</color>
    <color name="brand_yaml">#EF9A9A</color>
    <color name="brand_sh">#A5D6A7</color>
    <color name="brand_sql">#90CAF9</color>
    <color name="brand_md">#9E9E9E</color>
    <color name="brand_word">#90CAF9</color>
    <color name="brand_excel">#A5D6A7</color>
    <color name="brand_ppt">#FFAB91</color>
    <color name="brand_default">#9E9E9E</color>
</resources>
