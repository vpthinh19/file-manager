<?xml version="1.0" encoding="utf-8"?>
<!--
  Per-row cascade. delay=4% staggers row_fade_in so rows arrive from the top in sequence (not all
  at once), reading as a continuous "shutter drop" rather than a flash. Slightly tighter than the
  previous 6% so the whole cascade still completes within ~400ms for a typical 8-12 row pane.
-->
<layoutAnimation xmlns:android="http://schemas.android.com/apk/res/android"
    android:animation="@anim/row_fade_in"
    android:animationOrder="normal"
    android:delay="4%" />
