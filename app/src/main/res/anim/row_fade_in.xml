<?xml version="1.0" encoding="utf-8"?>
<!--
  Single-row enter animation — MT Manager style "drop from above":
   - alpha 0 → 1 (fade in)
   - translateY -22% → 0% (NEGATIVE start = row originates ABOVE its final position, falls down)
  Combined effect: rows appear to "rain down" from the top of the pane into place.

  Duration 280ms with linear_out_slow_in is the Material 3 enter standard — accelerates fast at the
  start and decelerates softly into the resting position, eliminating the abrupt "snap" that the
  previous fast_out_slow_in 220ms produced for a content-replace transition.
-->
<set xmlns:android="http://schemas.android.com/apk/res/android"
    android:duration="280"
    android:interpolator="@android:interpolator/linear_out_slow_in">

    <alpha
        android:fromAlpha="0"
        android:toAlpha="1" />

    <translate
        android:fromYDelta="-22%"
        android:toYDelta="0%" />
</set>
