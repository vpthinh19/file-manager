<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface"
    android:orientation="vertical">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/colorSurfaceContainer"
        android:fitsSystemWindows="true"
        app:elevation="0dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="?attr/colorSurfaceContainer"
            android:minHeight="64dp"
            app:contentInsetStartWithNavigation="0dp"
            app:navigationContentDescription="@string/menu_open_drawer"
            app:navigationIcon="@drawable/ic_menu"
            app:navigationIconTint="?attr/colorOnSurface"
            app:subtitleTextColor="?attr/colorOnSurfaceVariant"
            app:title=" "
            app:titleTextColor="?attr/colorOnSurface" />
    </com.google.android.material.appbar.AppBarLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal">

        <FrameLayout
            android:id="@+id/pane_left_container"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1" />

        <View
            android:id="@+id/divider_panes"
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:background="?attr/colorOutlineVariant" />

        <FrameLayout
            android:id="@+id/pane_right_container"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1" />
    </LinearLayout>

    <FrameLayout
        android:id="@+id/bottom_container"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:background="?attr/colorSurfaceContainer">

        <LinearLayout
            android:id="@+id/bottom_bar"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/btn_add"
                style="@style/BrowserBottomButton"
                android:contentDescription="@string/action_new_file"
                android:src="@drawable/ic_add" />

            <ImageButton
                android:id="@+id/btn_swap"
                style="@style/BrowserBottomButton"
                android:contentDescription="@string/menu_more_options"
                android:src="@drawable/ic_swap" />

            <ImageButton
                android:id="@+id/btn_up"
                style="@style/BrowserBottomButton"
                android:contentDescription="@string/action_up"
                android:src="@drawable/ic_arrow_up" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/selection_bar"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="horizontal"
            android:visibility="gone">

            <ImageButton
                android:id="@+id/btn_sel_cancel"
                style="@style/BrowserBottomButton"
                android:contentDescription="@string/menu_more_options"
                android:src="@drawable/ic_close" />

            <ImageButton
                android:id="@+id/btn_sel_all"
                style="@style/BrowserBottomButton"
                android:contentDescription="@string/menu_more_options"
                android:src="@drawable/ic_select_all" />

            <ImageButton
                android:id="@+id/btn_sel_more"
                style="@style/BrowserBottomButton"
                android:contentDescription="@string/menu_more_options"
                android:src="@drawable/ic_more" />
        </LinearLayout>
    </FrameLayout>
</LinearLayout>
