<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <!--
      android:fitsSystemWindows="true" + chrome background = the canonical Material 3 edge-to-edge
      pattern: AppBarLayout consumes the top WindowInset and pads the toolbar down to clear the
      status bar, while its background still fills its full bounds (including BEHIND the now-
      transparent status bar). Result: the chrome color paints both the toolbar and the status bar
      inset region in one shot — no race with windowBackground, no MIUI wallpaper bleed-through.

      Why no background on the LinearLayout root any more: AppBarLayout, the two pane FrameLayouts,
      and the bottom_container each own their colorSurface backgrounds. Removing the LinearLayout
      background ensures the windowBackground=chrome paints through anywhere those children don't
      cover (a belt-and-braces backstop for the inset region).

      liftOnScroll stays false because the M3 default lift blends colorSurface overlay into the
      toolbar bg when content scrolls under — which would split the chrome/status-bar color.
    -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/md_chrome_bg"
        app:elevation="0dp"
        app:liftOnScroll="false">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/md_chrome_bg"
            android:minHeight="64dp"
            app:contentInsetStartWithNavigation="0dp"
            app:navigationContentDescription="@string/menu_open_drawer"
            app:navigationIcon="@drawable/ic_menu"
            app:navigationIconTint="@color/md_chrome_on_bg">

            <!--
              Custom title block: we replace MaterialToolbar's built-in title TextView so we can
              tune font size + ellipsize=start. With ellipsize=start the leading characters drop to
              "..." and the meaningful end of the path stays visible at the right edge
              (e.g. "...mulated/0/Download/hehe"). Toolbar accepts arbitrary children via
              Toolbar.LayoutParams.
            -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tv_toolbar_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="start"
                    android:includeFontPadding="false"
                    android:singleLine="true"
                    android:textColor="@color/md_chrome_on_bg"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_toolbar_subtitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:includeFontPadding="false"
                    android:paddingTop="3dp"
                    android:singleLine="true"
                    android:textColor="@color/md_chrome_on_bg_variant"
                    android:textSize="12sp" />
            </LinearLayout>
        </com.google.android.material.appbar.MaterialToolbar>
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <FrameLayout
            android:id="@+id/pane_left_container"
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/divider_panes" />

        <View
            android:id="@+id/divider_panes"
            android:layout_width="1dp"
            android:layout_height="0dp"
            android:background="?attr/colorOutlineVariant"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@+id/pane_left_container"
            app:layout_constraintEnd_toStartOf="@+id/pane_right_container" />

        <FrameLayout
            android:id="@+id/pane_right_container"
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@+id/divider_panes"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <FrameLayout
        android:id="@+id/bottom_container"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:background="?attr/colorSurface">

        <LinearLayout
            android:id="@+id/bottom_bar"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/btn_back"
                style="@style/BrowserBottomButton"
                android:contentDescription="@string/action_back"
                android:src="@drawable/ic_arrow_back" />

            <ImageButton
                android:id="@+id/btn_forward"
                style="@style/BrowserBottomButton"
                android:contentDescription="@string/action_forward"
                android:src="@drawable/ic_arrow_forward" />

            <ImageButton
                android:id="@+id/btn_add"
                style="@style/BrowserBottomButton"
                android:contentDescription="@string/action_new_file"
                android:src="@drawable/ic_add" />

            <ImageButton
                android:id="@+id/btn_swap"
                style="@style/BrowserBottomButton"
                android:contentDescription="@string/action_swap"
                android:src="@drawable/ic_swap" />

            <ImageButton
                android:id="@+id/btn_up"
                style="@style/BrowserBottomButton"
                android:contentDescription="@string/action_up"
                android:src="@drawable/ic_arrow_up" />
        </LinearLayout>

        <!--
          Phase R-7a: 5 nút theo thứ tự select_all | deselect (keep mode) | X (center exit) |
          range | more. X ở center vì là affordance "exit hẳn" — vị trí trung tâm dễ tap nhanh.
          Deselect ≠ X: deselect clear items nhưng giữ mode active (user vẫn ở bar, có thể
          tap items để re-select); X exit hẳn về normal browser mode.
        -->
        <LinearLayout
            android:id="@+id/selection_bar"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="horizontal"
            android:visibility="gone">

            <ImageButton
                android:id="@+id/btn_sel_all"
                style="@style/BrowserBottomButton"
                android:contentDescription="@string/menu_more_options"
                android:src="@drawable/ic_select_all" />

            <ImageButton
                android:id="@+id/btn_sel_deselect"
                style="@style/BrowserBottomButton"
                android:contentDescription="@string/menu_more_options"
                android:src="@drawable/ic_deselect_all" />

            <ImageButton
                android:id="@+id/btn_sel_cancel"
                style="@style/BrowserBottomButton"
                android:contentDescription="@string/menu_more_options"
                android:src="@drawable/ic_close" />

            <ImageButton
                android:id="@+id/btn_sel_range"
                style="@style/BrowserBottomButton"
                android:contentDescription="@string/menu_more_options"
                android:src="@drawable/ic_select_range" />

            <ImageButton
                android:id="@+id/btn_sel_more"
                style="@style/BrowserBottomButton"
                android:contentDescription="@string/menu_more_options"
                android:src="@drawable/ic_more" />
        </LinearLayout>
    </FrameLayout>
</LinearLayout>
