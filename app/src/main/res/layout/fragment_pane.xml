<?xml version="1.0" encoding="utf-8"?>
<!--
  Single pane. The FrameLayout holds an active-pane indicator in its foreground (see
  bg_pane_indicator.xml) so the border is drawn AFTER children — no clipping by items.
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/pane_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface"
    android:foreground="@drawable/bg_pane_indicator"
    android:foregroundGravity="fill">

    <!--
      No row-level animation: large refreshes animate hundreds of items and degrade frame times.
    -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false" />

    <ProgressBar
        android:id="@+id/progress"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_gravity="center"
        android:visibility="gone" />
</FrameLayout>
