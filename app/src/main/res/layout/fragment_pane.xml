<?xml version="1.0" encoding="utf-8"?>
<!--
  Single pane. The FrameLayout holds an active-pane indicator in its foreground (see
  bg_pane_indicator.xml) so the border is drawn AFTER children — no clipping by items.
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/pane_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface"
    android:foreground="@drawable/bg_pane_indicator"
    android:foregroundGravity="fill">

    <!--
      No layoutAnimation declared: LayoutAnimationController races with DiffUtil + AsyncListDiffer
      commit timing — items are laid out at their resting position BEFORE the animation
      controller resets them to its start state, producing a one-frame flash of new content
      followed by the cascade. DefaultItemAnimator (configured in PaneFragment) handles per-item
      add/remove cross-fade synchronously with DiffUtil notifications, no race.
    -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false" />

    <ProgressBar
        android:id="@+id/progress"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_gravity="center"
        android:visibility="gone" />
</FrameLayout>
