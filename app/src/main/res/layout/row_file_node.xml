<?xml version="1.0" encoding="utf-8"?>
<!--
  Row item — sized for dual-pane density. Background uses a state-list (bg_file_row) that swaps to
  row_selected_bg when itemView is in selected state. Activation toggled via View#setSelected from
  adapter.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="46dp"
    android:background="@drawable/bg_file_row"
    android:foreground="?attr/selectableItemBackground"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingHorizontal="8dp">

    <com.vpt.filemanager.ui.browser.FileIconView
        android:id="@+id/file_icon"
        android:layout_width="30dp"
        android:layout_height="30dp" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingStart="5dp"
        android:paddingEnd="4dp">

        <TextView
            android:id="@+id/tv_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:singleLine="true"
            android:textColor="?attr/colorOnSurface"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/tv_meta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:singleLine="true"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:textSize="10sp" />
    </LinearLayout>
</LinearLayout>
