<?xml version="1.0" encoding="utf-8"?>
<!--
  Drawer header — simple branding block. Kept intentionally minimal (no account chip,
  no avatar) to match the "files-only" scope of the app.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/md_chrome_bg"
    android:gravity="bottom"
    android:minHeight="120dp"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/app_name"
        android:textColor="@color/md_chrome_on_bg"
        android:textSize="18sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:paddingTop="2dp"
        android:text="@string/drawer_subtitle"
        android:textColor="@color/md_chrome_on_bg_variant"
        android:textSize="12sp" />
</LinearLayout>
