<?xml version="1.0" encoding="utf-8"?>
<!--
  Properties dialog body — 2-column TableLayout: label (wrap_content) on the left, value
  (stretches) right-aligned. PropertiesDialogFragment populates each tv_value at runtime.
  Right-aligning the value column matches the MT Manager properties dialog: column edges line up,
  long values truncate from the start so the most meaningful end stays visible.
-->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingHorizontal="24dp"
    android:paddingTop="16dp"
    android:paddingBottom="8dp">

    <TableLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:stretchColumns="1">

        <TableRow android:layout_marginBottom="6dp">
            <TextView
                style="@style/PropertiesLabel"
                android:text="@string/properties_name" />
            <TextView
                android:id="@+id/tv_name"
                style="@style/PropertiesValue" />
        </TableRow>

        <TableRow android:layout_marginBottom="6dp">
            <TextView
                style="@style/PropertiesLabel"
                android:text="@string/properties_parent" />
            <TextView
                android:id="@+id/tv_parent"
                style="@style/PropertiesValue" />
        </TableRow>

        <TableRow android:layout_marginBottom="6dp">
            <TextView
                style="@style/PropertiesLabel"
                android:text="@string/properties_type" />
            <TextView
                android:id="@+id/tv_type"
                style="@style/PropertiesValue" />
        </TableRow>

        <TableRow android:layout_marginBottom="6dp">
            <TextView
                style="@style/PropertiesLabel"
                android:text="@string/properties_size" />
            <TextView
                android:id="@+id/tv_size"
                style="@style/PropertiesValue" />
        </TableRow>

        <TableRow android:layout_marginBottom="6dp">
            <TextView
                style="@style/PropertiesLabel"
                android:text="@string/properties_modified" />
            <TextView
                android:id="@+id/tv_modified"
                style="@style/PropertiesValue" />
        </TableRow>

        <TableRow android:layout_marginBottom="6dp">
            <TextView
                style="@style/PropertiesLabel"
                android:text="@string/properties_permissions" />
            <TextView
                android:id="@+id/tv_permissions"
                style="@style/PropertiesValue" />
        </TableRow>

        <TableRow android:layout_marginBottom="6dp">
            <TextView
                style="@style/PropertiesLabel"
                android:text="@string/properties_owner" />
            <TextView
                android:id="@+id/tv_owner"
                style="@style/PropertiesValue" />
        </TableRow>

        <TableRow>
            <TextView
                style="@style/PropertiesLabel"
                android:text="@string/properties_group" />
            <TextView
                android:id="@+id/tv_group"
                style="@style/PropertiesValue" />
        </TableRow>
    </TableLayout>
</ScrollView>
